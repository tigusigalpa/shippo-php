{
    "name": "tigusigalpa/shippo-php",
    "description": "Modern PHP SDK for the Shippo API with Laravel integration",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "shippo",
        "shipping",
        "api",
        "laravel",
        "php",
        "sdk",
        "labels",
        "tracking",
        "rates"
    ],
    "authors": [
        {
            "name": "Igor Sazonov",
            "email": "sovletig@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "phpstan/phpstan": "^1.10",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^9.0 || ^10.0 || ^11.0 || ^12.0",
        "orchestra/testbench": "^7.0 || ^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "Tigusigalpa\\Shippo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tigusigalpa\\Shippo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tigusigalpa\\Shippo\\Laravel\\ShippoServiceProvider"
            ],
            "aliases": {
                "Shippo": "Tigusigalpa\\Shippo\\Laravel\\Facades\\Shippo"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
